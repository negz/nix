{
  "$schema": "https://opencode.ai/config.json",
  "model": "anthropic/claude-opus-4-6",
  "small_model": "anthropic/claude-sonnet-4-5-20250929",
  "provider": {
    "anthropic": {
      "options": {
        "apiKey": "{file:~/.local/share/opencode/anthropic-api-key}"
      },
      "models": {
        "claude-opus-4-6": {
          "options": {
            "thinking": {
              "type": "enabled",
              "budgetTokens": 32000
            }
          }
        }
      }
    }
  },
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp"
    }
  },
  "permission": {
    "edit": "allow",
    "bash": {
      "*": "allow",
      "git push *": "ask",
      "git commit *": "ask",
      "rm *": "ask"
    }
  }
}
